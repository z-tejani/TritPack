import { ListView, Button, LineEdit, TextEdit } from "std-widgets.slint";

component PillButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <brush> selected-fill;
    in property <brush> idle-fill;
    in property <color> selected-text;
    in property <color> idle-text;
    in property <length> corner-radius: 18px;
    callback invoke();

    height: 36px;
    border-radius: corner-radius;
    background: selected ? selected-fill : idle-fill;
    border-width: selected ? 0px : 1px;
    border-color: selected ? #00000000 : #ffffff10;

    Text {
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: label;
        color: selected ? selected-text : idle-text;
        font-size: 14px;
        font-weight: 700;
        font-family: "SF Pro Display";
    }

    touch := TouchArea {
        clicked => { root.invoke(); }
    }
}

component IconCircle inherits Rectangle {
    in property <string> label;
    in property <brush> fill;
    in property <color> text-color;
    callback invoke();

    width: 38px;
    height: 38px;
    border-radius: 19px;
    background: fill;
    border-width: 1px;
    border-color: #ffffff10;

    Text {
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: label;
        color: text-color;
        font-size: 15px;
        font-weight: 700;
        font-family: "SF Pro Display";
    }

    touch := TouchArea {
        clicked => { root.invoke(); }
    }
}

component TrafficLight inherits Rectangle {
    in property <color> fill;
    in property <color> hover-fill;
    in property <string> symbol;
    callback invoke();

    property <bool> hovered: touch.has-hover;
    width: 14px;
    height: 14px;
    border-radius: 7px;
    background: hovered ? hover-fill : fill;
    border-width: 1px;
    border-color: #00000022;

    Text {
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: root.hovered ? root.symbol : "";
        color: #00000099;
        font-size: 10px;
        font-weight: 800;
        font-family: "SF Pro Display";
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.invoke(); }
    }
}

component PanelCard inherits Rectangle {
    in property <brush> fill;
    in property <color> edge;
    in property <length> radius: 22px;

    border-radius: radius;
    background: fill;
    border-width: 1px;
    border-color: edge;
    clip: true;

    @children
}

component SectionTitle inherits Text {
    color: #f8f9fd;
    font-size: 14px;
    font-weight: 700;
    font-family: "SF Pro Display";
}

component BodyText inherits Text {
    color: #aab0ca;
    font-size: 13px;
    font-family: "SF Pro Display";
}

component QuickTile inherits Rectangle {
    in property <string> icon;
    in property <string> title;
    in property <string> subtitle;
    in property <brush> fill;
    in property <color> edge;
    in property <color> title-color;
    in property <color> body-color;
    callback invoke();

    border-radius: 18px;
    background: fill;
    border-width: 1px;
    border-color: edge;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: 18px;
        spacing: 8px;

        Text {
            text: root.icon;
            color: root.title-color;
            font-size: 18px;
            font-weight: 700;
            font-family: "SF Pro Display";
        }

        Text {
            text: root.title;
            color: root.title-color;
            font-size: 16px;
            font-weight: 700;
            font-family: "SF Pro Display";
        }

        Text {
            text: root.subtitle;
            color: root.body-color;
            font-size: 12px;
            wrap: word-wrap;
            font-family: "SF Pro Display";
        }
    }

    touch := TouchArea {
        clicked => { root.invoke(); }
    }
}

component StreamRow inherits Rectangle {
    in property <string> value;
    in property <bool> alternate;
    in property <brush> fill;
    in property <brush> alternate-fill;
    in property <color> edge;
    in property <color> text-color;

    height: 64px;
    border-radius: 16px;
    background: alternate ? alternate-fill : fill;
    border-width: 1px;
    border-color: edge;

    Text {
        x: 16px;
        y: 14px;
        width: parent.width - 32px;
        text: value;
        color: text-color;
        font-size: 13px;
        wrap: word-wrap;
        font-family: "SF Pro Display";
    }
}

component EmptyState inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <color> title-color;
    in property <color> body-color;

    background: #00000000;

    VerticalLayout {
        x: (parent.width - 420px) / 2;
        y: (parent.height - 68px) / 2;
        width: 420px;
        spacing: 8px;

        Text {
            width: parent.width;
            horizontal-alignment: center;
            text: root.title;
            color: root.title-color;
            font-size: 18px;
            font-weight: 700;
            font-family: "SF Pro Display";
        }

        Text {
            width: parent.width;
            horizontal-alignment: center;
            text: root.body;
            color: root.body-color;
            font-size: 13px;
            wrap: word-wrap;
            font-family: "SF Pro Display";
        }
    }
}

export component AppWindow inherits Window {
    preferred-width: 1440px;
    preferred-height: 920px;
    min-width: 1120px;
    min-height: 760px;
    no-frame: true;
    resize-border-width: 7px;
    background: #00000000;
    title: "TritPack Desktop";

    in property <[string]> library-items;
    in property <[string]> job-items;
    in property <[string]> search-items;
    in property <[string]> detail-items;
    in property <[string]> runtime-items;
    in property <[string]> chat-items;
    in-out property <string> status-text: "";
    in-out property <string> import-path: "";
    in-out property <string> model-id-input: "";
    in-out property <string> hf-query: "";
    in-out property <string> search-index: "";
    in-out property <string> direct-url: "";
    in-out property <string> hf-token: "";
    in-out property <string> job-id-input: "";
    in-out property <string> chat-model-id: "";
    in-out property <string> chat-prompt: "";
    in-out property <int> selected-view: 0;
    in-out property <int> theme-mode: 0;

    callback refresh();
    callback import-local(string);
    callback queue-convert(string);
    callback prepare-runtime(string);
    callback inspect-model(string);
    callback search-models(string);
    callback download-url(string);
    callback download-search-result(string);
    callback refresh-runtime();
    callback cancel-job(string);
    callback send-prompt(string, string);
    callback save-token(string);
    callback clear-cache(string);
    callback close-window();
    callback minimize-window();
    callback toggle-maximize-window();
    callback begin-window-drag();

    property <bool> work-mode: root.selected-view != 0;
    property <string> page-title:
        root.selected-view == 1 ? "Library"
        : root.selected-view == 2 ? "Discover"
        : root.selected-view == 3 ? "Queue"
        : root.selected-view == 4 ? "Model Detail"
        : "Settings";
    property <string> page-subtitle:
        root.selected-view == 1 ? "Import GGUF models, inspect them, and move them into the TritPack workflow."
        : root.selected-view == 2 ? "Search Hugging Face or paste a direct GGUF URL to download new models."
        : root.selected-view == 3 ? "Track downloads, conversions, verification, and runtime preparation in one place."
        : root.selected-view == 4 ? "Inspect metadata, artifact sizes, and cached runtime readiness."
        : "Configure account access, theme, and runtime diagnostics for the llama.cpp release path.";

    property <brush> app-background: root.theme-mode == 0
        ? @linear-gradient(180deg, #5835ebd8 0%, #273db8cc 32%, #102d74c5 70%, #0b1b47bf 100%)
        : @linear-gradient(180deg, #090909e2 0%, #020202d8 100%);
    property <brush> shell-fill: root.theme-mode == 0
        ? @linear-gradient(180deg, #2a2351d7 0%, #1c2a58db 100%)
        : @linear-gradient(180deg, #121212e4 0%, #090909e8 100%);
    property <brush> shell-inner: root.theme-mode == 0 ? #ffffff0a : #ffffff06;
    property <brush> panel-fill: root.theme-mode == 0 ? #ffffff12 : #111111d2;
    property <brush> panel-strong: root.theme-mode == 0 ? #ffffff16 : #1a1a1ad6;
    property <brush> panel-soft: root.theme-mode == 0 ? #ffffff10 : #0f0f0fd2;
    property <brush> chip-fill: root.theme-mode == 0 ? #191d37da : #121212;
    property <brush> chip-active: root.theme-mode == 0 ? #3d456fe6 : #292929;
    property <brush> composer-fill: root.theme-mode == 0 ? #313650c8 : #181818d0;
    property <brush> row-fill: root.theme-mode == 0 ? #ffffff08 : #121212;
    property <brush> row-alt-fill: root.theme-mode == 0 ? #ffffff05 : #0c0c0c;
    property <brush> orb-fill: root.theme-mode == 0
        ? @radial-gradient(circle, #f2fbff 0%, #dff6ff 42%, #bfe7ff 70%, #a4d6ff 100%)
        : @radial-gradient(circle, #fafafa 0%, #d8d8d8 100%);
    property <color> shell-edge: root.theme-mode == 0 ? #ffffff18 : #ffffff10;
    property <color> accent-edge: root.theme-mode == 0 ? #91cbff22 : #ffffff10;
    property <color> text-primary: #f7f8fb;
    property <color> text-secondary: root.theme-mode == 0 ? #d7dcef : #b7b7b7;
    property <color> text-muted: root.theme-mode == 0 ? #97a2c0 : #787878;
    property <color> accent-text: root.theme-mode == 0 ? #dff3ff : #ffffff;

    Rectangle {
        width: 100%;
        height: 100%;
        background: #00000000;

        PanelCard {
            x: 4px;
            y: 4px;
            width: parent.width - 8px;
            height: parent.height - 8px;
            fill: root.shell-fill;
            edge: root.shell-edge;
            radius: 24px;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: root.app-background;

                if (root.theme-mode == 0) : Rectangle {
                    x: -140px;
                    y: parent.height - 310px;
                    width: 420px;
                    height: 240px;
                    border-radius: 120px;
                    background: #d8f2ff1d;
                }

                if (root.theme-mode == 0) : Rectangle {
                    x: parent.width - 250px;
                    y: -60px;
                    width: 290px;
                    height: 210px;
                    border-radius: 120px;
                    background: #9ad8ff12;
                }

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding: 20px;
                    spacing: 16px;

                    Rectangle {
                        height: 44px;
                        background: #00000000;

                        TouchArea {
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: grab;
                            pointer-event(event) => {
                                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                    root.begin-window-drag();
                                }
                            }
                        }

                        HorizontalLayout {
                            width: parent.width;
                            height: parent.height;
                            spacing: 14px;

                            HorizontalLayout {
                                spacing: 10px;

                                TrafficLight {
                                    fill: #ff5f57;
                                    hover-fill: #ff7b74;
                                    symbol: "×";
                                    invoke => { root.close-window(); }
                                }

                                TrafficLight {
                                    fill: #febc2e;
                                    hover-fill: #ffd45b;
                                    symbol: "−";
                                    invoke => { root.minimize-window(); }
                                }

                                TrafficLight {
                                    fill: #28c840;
                                    hover-fill: #52db6b;
                                    symbol: "+";
                                    invoke => { root.toggle-maximize-window(); }
                                }

                                PillButton {
                                    label: "TritPack";
                                    selected: false;
                                    selected-fill: root.chip-active;
                                    idle-fill: root.chip-fill;
                                    selected-text: root.text-primary;
                                    idle-text: root.text-secondary;
                                    preferred-width: 94px;
                                    invoke => { root.selected-view = 0; }
                                }
                            }

                            Rectangle { horizontal-stretch: 1; background: #00000000; }

                            Rectangle {
                                width: 190px;
                                height: 40px;
                                border-radius: 20px;
                                background: root.chip-fill;
                                border-width: 1px;
                                border-color: root.shell-edge;

                                HorizontalLayout {
                                    width: parent.width;
                                    height: parent.height;
                                    padding: 4px;
                                    spacing: 6px;

                                    PillButton {
                                        label: "Chat";
                                        selected: !root.work-mode;
                                        selected-fill: root.chip-active;
                                        idle-fill: #00000000;
                                        selected-text: root.text-primary;
                                        idle-text: root.text-secondary;
                                        horizontal-stretch: 1;
                                        invoke => { root.selected-view = 0; }
                                    }

                                    PillButton {
                                        label: "Configure";
                                        selected: root.work-mode;
                                        selected-fill: root.chip-active;
                                        idle-fill: #00000000;
                                        selected-text: root.text-primary;
                                        idle-text: root.text-secondary;
                                        horizontal-stretch: 1;
                                        invoke => { root.selected-view = root.selected-view == 0 ? 1 : root.selected-view; }
                                    }
                                }
                            }

                            Rectangle { horizontal-stretch: 1; background: #00000000; }

                            HorizontalLayout {
                                spacing: 10px;

                                IconCircle {
                                    label: root.theme-mode == 0 ? "◐" : "●";
                                    fill: root.chip-fill;
                                    text-color: root.text-secondary;
                                    invoke => { root.theme-mode = root.theme-mode == 0 ? 1 : 0; }
                                }

                                IconCircle {
                                    label: "⚙";
                                    fill: root.chip-fill;
                                    text-color: root.text-secondary;
                                    invoke => { root.selected-view = 5; }
                                }
                            }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: #00000000;

                        if (!root.work-mode) : Rectangle {
                            width: parent.width;
                            height: parent.height;
                            background: #00000000;

                            if (root.chat-items.length == 0) : VerticalLayout {
                                x: (parent.width - 760px) / 2;
                                y: 34px;
                                width: 760px;
                                spacing: 20px;

                                Rectangle {
                                    x: (parent.width - 92px) / 2;
                                    width: 92px;
                                    height: 92px;
                                    border-radius: 46px;
                                    background: root.orb-fill;
                                    drop-shadow-blur: 36px;
                                    drop-shadow-color: root.theme-mode == 0 ? #d5f7ff8a : #ffffff33;
                                    drop-shadow-offset-x: 0px;
                                    drop-shadow-offset-y: 0px;

                                    Rectangle { x: 29px; y: 26px; width: 7px; height: 7px; border-radius: 4px; background: #ffffff99; }
                                    Rectangle { x: 47px; y: 32px; width: 5px; height: 5px; border-radius: 3px; background: #ffffffdd; }
                                    Rectangle { x: 39px; y: 49px; width: 6px; height: 6px; border-radius: 3px; background: #ffffffaa; }
                                }

                                Text {
                                    width: parent.width;
                                    horizontal-alignment: center;
                                    text: "Good afternoon";
                                    color: root.text-primary;
                                    font-size: 42px;
                                    font-weight: 800;
                                    font-family: "SF Pro Display";
                                }

                                Text {
                                    width: parent.width;
                                    horizontal-alignment: center;
                                    text: "How can TritPack help you today?";
                                    color: root.text-secondary;
                                    font-size: 17px;
                                    font-family: "SF Pro Display";
                                }

                                Text {
                                    width: parent.width;
                                    horizontal-alignment: center;
                                    text: "TritPack";
                                    color: root.accent-text;
                                    font-size: 15px;
                                    font-weight: 700;
                                    font-family: "SF Pro Display";
                                }

                                Rectangle {
                                    width: parent.width;
                                    height: 182px;
                                    background: #00000000;

                                    GridLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        spacing: 14px;

                                        QuickTile {
                                            row: 0;
                                            col: 0;
                                            title: "Import a model";
                                            subtitle: "Bring in a local GGUF and move it into the TritPack flow.";
                                            icon: "↥";
                                            fill: root.panel-fill;
                                            edge: root.accent-edge;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 1; }
                                        }

                                        QuickTile {
                                            row: 0;
                                            col: 1;
                                            title: "Discover GGUFs";
                                            subtitle: "Search Hugging Face repositories and queue downloads.";
                                            icon: "⌕";
                                            fill: root.panel-fill;
                                            edge: root.accent-edge;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 2; }
                                        }

                                        QuickTile {
                                            row: 1;
                                            col: 0;
                                            title: "Check the queue";
                                            subtitle: "Monitor downloads, conversions, verification, and runtime prep.";
                                            icon: "≣";
                                            fill: root.panel-fill;
                                            edge: root.accent-edge;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 3; }
                                        }

                                        QuickTile {
                                            row: 1;
                                            col: 1;
                                            title: "Open settings";
                                            subtitle: "Review runtime health, tokens, and release preferences.";
                                            icon: "⚙";
                                            fill: root.panel-fill;
                                            edge: root.accent-edge;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 5; }
                                        }
                                    }
                                }

                                PanelCard {
                                    fill: root.shell-inner;
                                    edge: root.shell-edge;
                                    radius: 20px;
                                    height: 54px;

                                    HorizontalLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        padding: 12px;
                                        spacing: 12px;

                                        PillButton {
                                            label: "llama.cpp release";
                                            selected: true;
                                            selected-fill: root.chip-active;
                                            idle-fill: root.chip-fill;
                                            selected-text: root.text-primary;
                                            idle-text: root.text-secondary;
                                            preferred-width: 128px;
                                            invoke => { }
                                        }

                                        PillButton {
                                            label: "GGUF only";
                                            selected: false;
                                            selected-fill: root.chip-active;
                                            idle-fill: root.chip-fill;
                                            selected-text: root.text-primary;
                                            idle-text: root.text-secondary;
                                            preferred-width: 96px;
                                            invoke => { }
                                        }

                                        Rectangle { horizontal-stretch: 1; background: #00000000; }

                                        Text {
                                            text: root.status-text;
                                            color: root.text-muted;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            font-family: "SF Pro Display";
                                        }
                                    }
                                }
                            }

                            if (root.chat-items.length > 0) : PanelCard {
                                x: (parent.width - 840px) / 2;
                                y: 18px;
                                width: 840px;
                                height: parent.height - 24px;
                                fill: root.panel-soft;
                                edge: root.shell-edge;
                                radius: 24px;

                                VerticalLayout {
                                    width: parent.width;
                                    height: parent.height;
                                    padding: 18px;
                                    spacing: 12px;

                                    HorizontalLayout {
                                        SectionTitle { text: "Conversation"; }
                                        Rectangle { horizontal-stretch: 1; background: #00000000; }
                                        BodyText { text: root.status-text; }
                                    }

                                    ListView {
                                        width: parent.width;
                                        height: parent.height;
                                        for item[index] in root.chat-items : StreamRow {
                                            value: item;
                                            alternate: Math.mod(index, 2) == 1;
                                            fill: root.row-fill;
                                            alternate-fill: root.row-alt-fill;
                                            edge: root.shell-edge;
                                            text-color: root.text-primary;
                                        }
                                    }
                                }
                            }
                        }

                        if (root.work-mode) : VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            spacing: 14px;

                            Rectangle {
                                height: 80px;
                                background: #00000000;

                                Text {
                                    text: root.page-title;
                                    color: root.text-primary;
                                    font-size: 30px;
                                    font-weight: 800;
                                    font-family: "SF Pro Display";
                                }

                                Text {
                                    y: 40px;
                                    width: parent.width - 340px;
                                    text: root.page-subtitle;
                                    color: root.text-secondary;
                                    font-size: 14px;
                                    font-family: "SF Pro Display";
                                }

                                PanelCard {
                                    x: parent.width - 280px;
                                    y: 4px;
                                    width: 220px;
                                    height: 52px;
                                    fill: root.panel-soft;
                                    edge: root.shell-edge;
                                    radius: 18px;

                                    Text {
                                        x: 14px;
                                        y: 9px;
                                        width: parent.width - 28px;
                                        text: root.status-text;
                                        color: root.text-secondary;
                                        font-size: 11px;
                                        wrap: word-wrap;
                                        font-family: "SF Pro Display";
                                    }
                                }
                            }

                            Rectangle {
                                height: 40px;
                                background: #00000000;

                                HorizontalLayout {
                                    spacing: 10px;

                                    PillButton {
                                        label: "Library";
                                        selected: root.selected-view == 1;
                                        selected-fill: root.chip-active;
                                        idle-fill: root.chip-fill;
                                        selected-text: root.text-primary;
                                        idle-text: root.text-secondary;
                                        preferred-width: 92px;
                                        invoke => { root.selected-view = 1; }
                                    }

                                    PillButton {
                                        label: "Discover";
                                        selected: root.selected-view == 2;
                                        selected-fill: root.chip-active;
                                        idle-fill: root.chip-fill;
                                        selected-text: root.text-primary;
                                        idle-text: root.text-secondary;
                                        preferred-width: 100px;
                                        invoke => { root.selected-view = 2; }
                                    }

                                    PillButton {
                                        label: "Queue";
                                        selected: root.selected-view == 3;
                                        selected-fill: root.chip-active;
                                        idle-fill: root.chip-fill;
                                        selected-text: root.text-primary;
                                        idle-text: root.text-secondary;
                                        preferred-width: 84px;
                                        invoke => { root.selected-view = 3; }
                                    }

                                    PillButton {
                                        label: "Model Detail";
                                        selected: root.selected-view == 4;
                                        selected-fill: root.chip-active;
                                        idle-fill: root.chip-fill;
                                        selected-text: root.text-primary;
                                        idle-text: root.text-secondary;
                                        preferred-width: 118px;
                                        invoke => { root.selected-view = 4; }
                                    }

                                    PillButton {
                                        label: "Settings";
                                        selected: root.selected-view == 5;
                                        selected-fill: root.chip-active;
                                        idle-fill: root.chip-fill;
                                        selected-text: root.text-primary;
                                        idle-text: root.text-secondary;
                                        preferred-width: 92px;
                                        invoke => { root.selected-view = 5; }
                                    }
                                }
                            }

                            if (root.selected-view == 1) : VerticalLayout {
                                spacing: 14px;

                                PanelCard {
                                    fill: root.panel-strong;
                                    edge: root.shell-edge;
                                    radius: 22px;
                                    height: 110px;

                                    VerticalLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        padding: 14px;
                                        spacing: 10px;

                                        HorizontalLayout {
                                            spacing: 10px;
                                            LineEdit { text <=> root.import-path; placeholder-text: "Path to local .gguf"; horizontal-stretch: 1; }
                                            Button { text: "Import"; clicked => { root.import-local(root.import-path); } }
                                            Button { text: "Refresh"; clicked => { root.refresh(); } }
                                        }

                                        HorizontalLayout {
                                            spacing: 10px;
                                            LineEdit { text <=> root.model-id-input; placeholder-text: "Model ID"; horizontal-stretch: 1; }
                                            Button { text: "Inspect"; clicked => { root.inspect-model(root.model-id-input); root.selected-view = 4; } }
                                            Button { text: "Convert"; clicked => { root.queue-convert(root.model-id-input); } }
                                            Button { text: "Prepare"; clicked => { root.prepare-runtime(root.model-id-input); } }
                                            Button { text: "Clear Cache"; clicked => { root.clear-cache(root.model-id-input); } }
                                        }
                                    }
                                }

                                PanelCard {
                                    fill: root.panel-fill;
                                    edge: root.shell-edge;
                                    vertical-stretch: 1;

                                    if (root.library-items.length == 0) : EmptyState {
                                        width: parent.width;
                                        height: parent.height;
                                        title: "No models imported yet";
                                        body: "Import a GGUF model to start building your TritPack desktop library.";
                                        title-color: root.text-primary;
                                        body-color: root.text-secondary;
                                    }

                                    if (root.library-items.length > 0) : ListView {
                                        width: parent.width;
                                        height: parent.height;
                                        for item[index] in root.library-items : StreamRow {
                                            value: item;
                                            alternate: Math.mod(index, 2) == 1;
                                            fill: root.row-fill;
                                            alternate-fill: root.row-alt-fill;
                                            edge: root.shell-edge;
                                            text-color: root.text-primary;
                                        }
                                    }
                                }
                            }

                            if (root.selected-view == 2) : VerticalLayout {
                                spacing: 14px;

                                PanelCard {
                                    fill: root.panel-strong;
                                    edge: root.shell-edge;
                                    radius: 22px;
                                    height: 150px;

                                    VerticalLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        padding: 14px;
                                        spacing: 10px;

                                        HorizontalLayout {
                                            spacing: 10px;
                                            LineEdit { text <=> root.hf-query; placeholder-text: "Search Hugging Face for GGUF"; horizontal-stretch: 1; }
                                            Button { text: "Search"; clicked => { root.search-models(root.hf-query); } }
                                        }

                                        HorizontalLayout {
                                            spacing: 10px;
                                            LineEdit { text <=> root.search-index; placeholder-text: "Search result #"; horizontal-stretch: 1; }
                                            Button { text: "Download Result"; clicked => { root.download-search-result(root.search-index); } }
                                        }

                                        HorizontalLayout {
                                            spacing: 10px;
                                            LineEdit { text <=> root.direct-url; placeholder-text: "Direct GGUF URL"; horizontal-stretch: 1; }
                                            Button { text: "Download URL"; clicked => { root.download-url(root.direct-url); } }
                                        }
                                    }
                                }

                                PanelCard {
                                    fill: root.panel-fill;
                                    edge: root.shell-edge;
                                    vertical-stretch: 1;

                                    if (root.search-items.length == 0) : EmptyState {
                                        width: parent.width;
                                        height: parent.height;
                                        title: "No search results yet";
                                        body: "Search for a GGUF model on Hugging Face or paste a direct artifact URL.";
                                        title-color: root.text-primary;
                                        body-color: root.text-secondary;
                                    }

                                    if (root.search-items.length > 0) : ListView {
                                        width: parent.width;
                                        height: parent.height;
                                        for item[index] in root.search-items : StreamRow {
                                            value: item;
                                            alternate: Math.mod(index, 2) == 1;
                                            fill: root.row-fill;
                                            alternate-fill: root.row-alt-fill;
                                            edge: root.shell-edge;
                                            text-color: root.text-primary;
                                        }
                                    }
                                }
                            }

                            if (root.selected-view == 3) : VerticalLayout {
                                spacing: 14px;

                                PanelCard {
                                    fill: root.panel-strong;
                                    edge: root.shell-edge;
                                    radius: 22px;
                                    height: 72px;

                                    HorizontalLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        padding: 14px;
                                        spacing: 10px;

                                        LineEdit { text <=> root.job-id-input; placeholder-text: "Job ID"; horizontal-stretch: 1; }
                                        Button { text: "Cancel"; clicked => { root.cancel-job(root.job-id-input); } }
                                        Button { text: "Refresh"; clicked => { root.refresh(); } }
                                    }
                                }

                                PanelCard {
                                    fill: root.panel-fill;
                                    edge: root.shell-edge;
                                    vertical-stretch: 1;

                                    if (root.job-items.length == 0) : EmptyState {
                                        width: parent.width;
                                        height: parent.height;
                                        title: "No jobs in flight";
                                        body: "Queue a download, conversion, or runtime preparation job to populate this view.";
                                        title-color: root.text-primary;
                                        body-color: root.text-secondary;
                                    }

                                    if (root.job-items.length > 0) : ListView {
                                        width: parent.width;
                                        height: parent.height;
                                        for item[index] in root.job-items : StreamRow {
                                            value: item;
                                            alternate: Math.mod(index, 2) == 1;
                                            fill: root.row-fill;
                                            alternate-fill: root.row-alt-fill;
                                            edge: root.shell-edge;
                                            text-color: root.text-primary;
                                        }
                                    }
                                }
                            }

                            if (root.selected-view == 4) : VerticalLayout {
                                spacing: 14px;

                                PanelCard {
                                    fill: root.panel-strong;
                                    edge: root.shell-edge;
                                    radius: 22px;
                                    height: 72px;

                                    HorizontalLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        padding: 14px;
                                        spacing: 10px;

                                        LineEdit { text <=> root.model-id-input; placeholder-text: "Model ID"; horizontal-stretch: 1; }
                                        Button { text: "Inspect"; clicked => { root.inspect-model(root.model-id-input); } }
                                        Button { text: "Prepare"; clicked => { root.prepare-runtime(root.model-id-input); } }
                                    }
                                }

                                PanelCard {
                                    fill: root.panel-fill;
                                    edge: root.shell-edge;
                                    vertical-stretch: 1;

                                    if (root.detail-items.length == 0) : EmptyState {
                                        width: parent.width;
                                        height: parent.height;
                                        title: "No model detail loaded";
                                        body: "Inspect a model to surface metadata, artifact sizes, and runtime preparation info.";
                                        title-color: root.text-primary;
                                        body-color: root.text-secondary;
                                    }

                                    if (root.detail-items.length > 0) : ListView {
                                        width: parent.width;
                                        height: parent.height;
                                        for item[index] in root.detail-items : StreamRow {
                                            value: item;
                                            alternate: Math.mod(index, 2) == 1;
                                            fill: root.row-fill;
                                            alternate-fill: root.row-alt-fill;
                                            edge: root.shell-edge;
                                            text-color: root.text-primary;
                                        }
                                    }
                                }
                            }

                            if (root.selected-view == 5) : HorizontalLayout {
                                spacing: 14px;
                                vertical-stretch: 1;

                                PanelCard {
                                    fill: root.panel-fill;
                                    edge: root.shell-edge;
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;

                                    VerticalLayout {
                                        padding: 16px;
                                        spacing: 12px;

                                        SectionTitle { text: "Account & Theme"; }
                                        BodyText { text: "Save your Hugging Face token and switch between the release themes."; }
                                        LineEdit { text <=> root.hf-token; placeholder-text: "Hugging Face token"; }
                                        Button { text: "Save Token"; clicked => { root.save-token(root.hf-token); } }

                                        HorizontalLayout {
                                            spacing: 10px;

                                            PillButton {
                                                label: "Liquid Glass";
                                                selected: root.theme-mode == 0;
                                                selected-fill: root.chip-active;
                                                idle-fill: root.chip-fill;
                                                selected-text: root.text-primary;
                                                idle-text: root.text-secondary;
                                                horizontal-stretch: 1;
                                                invoke => { root.theme-mode = 0; }
                                            }

                                            PillButton {
                                                label: "Blackout";
                                                selected: root.theme-mode == 1;
                                                selected-fill: root.chip-active;
                                                idle-fill: root.chip-fill;
                                                selected-text: root.text-primary;
                                                idle-text: root.text-secondary;
                                                horizontal-stretch: 1;
                                                invoke => { root.theme-mode = 1; }
                                            }
                                        }
                                    }
                                }

                                PanelCard {
                                    fill: root.panel-fill;
                                    edge: root.shell-edge;
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;

                                    VerticalLayout {
                                        padding: 16px;
                                        spacing: 12px;

                                        HorizontalLayout {
                                            SectionTitle { text: "Runtime Diagnostics"; }
                                            Rectangle { horizontal-stretch: 1; background: #00000000; }
                                            Button { text: "Refresh"; clicked => { root.refresh-runtime(); } }
                                        }

                                        Rectangle {
                                            vertical-stretch: 1;
                                            background: #00000000;

                                            if (root.runtime-items.length == 0) : EmptyState {
                                                width: parent.width;
                                                height: parent.height;
                                                title: "No runtime diagnostics";
                                                body: "Refresh to inspect the worker, bundled runtime, and current macOS desktop setup.";
                                                title-color: root.text-primary;
                                                body-color: root.text-secondary;
                                            }

                                            if (root.runtime-items.length > 0) : ListView {
                                                width: parent.width;
                                                height: parent.height;
                                                for item[index] in root.runtime-items : StreamRow {
                                                    value: item;
                                                    alternate: Math.mod(index, 2) == 1;
                                                    fill: root.row-fill;
                                                    alternate-fill: root.row-alt-fill;
                                                    edge: root.shell-edge;
                                                    text-color: root.text-primary;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    PanelCard {
                        fill: root.shell-inner;
                        edge: root.shell-edge;
                        radius: 24px;
                        height: 124px;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: 14px;
                            spacing: 10px;

                            HorizontalLayout {
                                spacing: 8px;

                                PillButton {
                                    label: root.work-mode ? "Configure" : "Chat";
                                    selected: true;
                                    selected-fill: root.chip-active;
                                    idle-fill: root.chip-fill;
                                    selected-text: root.text-primary;
                                    idle-text: root.text-secondary;
                                    preferred-width: 86px;
                                    invoke => { }
                                }

                                LineEdit {
                                    text <=> root.chat-model-id;
                                    placeholder-text: "Model ID";
                                    preferred-width: 220px;
                                }

                                Rectangle { horizontal-stretch: 1; background: #00000000; }

                                BodyText { text: root.status-text; }
                            }

                            PanelCard {
                                fill: root.composer-fill;
                                edge: root.shell-edge;
                                radius: 20px;
                                vertical-stretch: 1;

                                HorizontalLayout {
                                    width: parent.width;
                                    height: parent.height;
                                    padding: 12px;
                                    spacing: 12px;

                                    IconCircle {
                                        label: "＋";
                                        fill: root.chip-fill;
                                        text-color: root.text-secondary;
                                        invoke => { }
                                    }

                                    TextEdit {
                                        text <=> root.chat-prompt;
                                        wrap: word-wrap;
                                        horizontal-stretch: 1;
                                    }

                                    Button {
                                        text: "Send";
                                        clicked => { root.send-prompt(root.chat-model-id, root.chat-prompt); }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
