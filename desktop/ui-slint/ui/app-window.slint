import { ListView, Button, LineEdit } from "std-widgets.slint";

component PillButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <brush> selected-fill;
    in property <brush> idle-fill;
    in property <color> selected-text;
    in property <color> idle-text;
    in property <length> corner-radius: 18px;
    callback invoke();

    height: 36px;
    border-radius: corner-radius;
    background: selected ? selected-fill : idle-fill;
    border-width: selected ? 0px : 1px;
    border-color: selected ? #00000000 : #ffffff10;

    Text {
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: label;
        color: selected ? selected-text : idle-text;
        font-size: 14px;
        font-weight: 700;
        font-family: "SF Pro Display";
    }

    touch := TouchArea {
        clicked => { root.invoke(); }
    }
}

component IconCircle inherits Rectangle {
    in property <string> label;
    in property <brush> fill;
    in property <color> text-color;
    callback invoke();

    width: 38px;
    height: 38px;
    border-radius: 19px;
    background: fill;
    border-width: 1px;
    border-color: #ffffff10;

    Text {
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: label;
        color: text-color;
        font-size: 15px;
        font-weight: 700;
        font-family: "SF Pro Display";
    }

    touch := TouchArea {
        clicked => { root.invoke(); }
    }
}

component TrafficLight inherits Rectangle {
    in property <color> fill;
    in property <color> hover-fill;
    in property <string> symbol;
    callback invoke();

    property <bool> hovered: touch.has-hover;
    width: 14px;
    height: 14px;
    border-radius: 7px;
    background: hovered ? hover-fill : fill;
    border-width: 1px;
    border-color: #00000022;

    Text {
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: root.hovered ? root.symbol : "";
        color: #00000099;
        font-size: 10px;
        font-weight: 800;
        font-family: "SF Pro Display";
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.invoke(); }
    }
}

component PanelCard inherits Rectangle {
    in property <brush> fill;
    in property <color> edge;
    in property <length> radius: 22px;

    border-radius: radius;
    background: fill;
    border-width: 1px;
    border-color: edge;
    clip: true;

    @children
}

component SectionTitle inherits Text {
    color: #f8f9fd;
    font-size: 14px;
    font-weight: 700;
    font-family: "SF Pro Display";
}

component BodyText inherits Text {
    color: #aab0ca;
    font-size: 13px;
    font-family: "SF Pro Display";
}

component QuickTile inherits Rectangle {
    in property <string> icon;
    in property <string> title;
    in property <string> subtitle;
    in property <brush> fill;
    in property <color> edge;
    in property <color> title-color;
    in property <color> body-color;
    callback invoke();

    border-radius: 18px;
    background: fill;
    border-width: 1px;
    border-color: edge;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: 18px;
        spacing: 8px;

        Text {
            text: root.icon;
            color: root.title-color;
            font-size: 18px;
            font-weight: 700;
            font-family: "SF Pro Display";
        }

        Text {
            text: root.title;
            color: root.title-color;
            font-size: 16px;
            font-weight: 700;
            font-family: "SF Pro Display";
        }

        Text {
            text: root.subtitle;
            color: root.body-color;
            font-size: 12px;
            wrap: word-wrap;
            font-family: "SF Pro Display";
        }
    }

    touch := TouchArea {
        clicked => { root.invoke(); }
    }
}

component StreamRow inherits Rectangle {
    in property <string> value;
    in property <bool> alternate;
    in property <bool> selected: false;
    in property <bool> interactive: false;
    in property <brush> fill;
    in property <brush> alternate-fill;
    in property <brush> selected-fill: #ffffff14;
    in property <color> edge;
    in property <color> text-color;
    callback invoke();

    height: 84px;
    border-radius: 16px;
    background: selected ? selected-fill : (alternate ? alternate-fill : fill);
    border-width: 1px;
    border-color: edge;

    Text {
        x: 16px;
        y: 12px;
        width: parent.width - 32px;
        height: parent.height - 24px;
        text: value;
        color: text-color;
        font-size: 13px;
        wrap: word-wrap;
        font-family: "SF Pro Display";
    }

    touch := TouchArea {
        enabled: root.interactive;
        mouse-cursor: root.interactive ? pointer : default;
        clicked => { root.invoke(); }
    }
}

component EmptyState inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <color> title-color;
    in property <color> body-color;

    background: #00000000;

    VerticalLayout {
        x: (parent.width - 420px) / 2;
        y: (parent.height - 68px) / 2;
        width: 420px;
        spacing: 8px;

        Text {
            width: parent.width;
            horizontal-alignment: center;
            text: root.title;
            color: root.title-color;
            font-size: 18px;
            font-weight: 700;
            font-family: "SF Pro Display";
        }

        Text {
            width: parent.width;
            horizontal-alignment: center;
            text: root.body;
            color: root.body-color;
            font-size: 13px;
            wrap: word-wrap;
            font-family: "SF Pro Display";
        }
    }
}

component SidebarItem inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <brush> selected-fill;
    in property <brush> idle-fill;
    in property <color> title-color;
    in property <color> body-color;
    callback invoke();

    height: 40px;
    border-radius: 14px;
    background: selected ? selected-fill : idle-fill;
    border-width: selected ? 0px : 1px;
    border-color: #ffffff10;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 14px;
        padding-right: 14px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 0px;

        Text {
            text: root.label;
            color: root.title-color;
            font-size: 13px;
            font-weight: 700;
            font-family: "SF Pro Display";
        }

    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.invoke(); }
    }
}

export component AppWindow inherits Window {
    preferred-width: 1440px;
    preferred-height: 920px;
    min-width: 1120px;
    min-height: 760px;
    no-frame: true;
    resize-border-width: 7px;
    background: #00000000;
    title: "TritPack Desktop";
    forward-focus: shortcut-scope;

    in property <[string]> library-items;
    in property <[string]> job-items;
    in property <[string]> search-items;
    in property <[string]> detail-items;
    in property <[string]> runtime-items;
    in property <[string]> chat-items;
    in property <[string]> saved-chat-items;
    in-out property <string> status-text: "";
    in-out property <string> import-path: "";
    in-out property <string> model-id-input: "";
    in-out property <string> hf-query: "";
    in-out property <string> search-index: "";
    in-out property <string> direct-url: "";
    in-out property <string> hf-token: "";
    in-out property <string> job-id-input: "";
    in-out property <string> chat-model-id: "";
    in-out property <string> chat-prompt: "";
    in-out property <string> greeting-text: "Hello";
    in-out property <int> selected-view: 0;
    in-out property <int> theme-mode: 1;
    in-out property <int> selected-library-index: -1;
    in-out property <int> selected-search-index: -1;
    in-out property <int> selected-saved-chat-index: -1;
    in-out property <bool> chat-drawer-open: false;

    callback refresh();
    callback import-local(string);
    callback queue-convert(string);
    callback prepare-runtime(string);
    callback inspect-model(string);
    callback search-models(string);
    callback download-url(string);
    callback download-search-result(string);
    callback refresh-runtime();
    callback cancel-job(string);
    callback send-prompt(string, string);
    callback save-token(string);
    callback clear-cache(string);
    callback close-window();
    callback minimize-window();
    callback toggle-maximize-window();
    callback begin-window-drag();
    callback quit-app();
    callback show-about();
    callback open-project-guide();
    callback open-local-models-guide();
    callback select-library-item(int);
    callback select-search-item(int);
    callback select-saved-chat-item(int);
    callback set-theme-mode(int);

    MenuBar {
        Menu {
            title: "TritPack";

            MenuItem {
                title: "About TritPack";
                activated => { root.show-about(); }
            }

            MenuItem {
                title: "Settings...";
                activated => { root.selected-view = 5; }
            }

            MenuSeparator {}

            MenuItem {
                title: "Quit TritPack";
                activated => { root.quit-app(); }
            }
        }

        Menu {
            title: "File";

            MenuItem {
                title: "Queue";
                activated => { root.selected-view = 3; }
            }

            MenuItem {
                title: "Runtime";
                activated => { root.selected-view = 4; }
            }

            MenuItem {
                title: "Settings...";
                activated => { root.selected-view = 5; }
            }

            MenuSeparator {}

            MenuItem {
                title: "Close Window";
                activated => { root.close-window(); }
            }
        }

        Menu {
            title: "Models";

            MenuItem {
                title: "Models";
                activated => { root.selected-view = 1; }
            }

            MenuItem {
                title: "Discover";
                activated => { root.selected-view = 2; }
            }
        }

        Menu {
            title: "Edit";

            MenuItem { title: "Cut"; enabled: false; }
            MenuItem { title: "Copy"; enabled: false; }
            MenuItem { title: "Paste"; enabled: false; }
            MenuItem { title: "Select All"; enabled: false; }
        }

        Menu {
            title: "View";

            MenuItem {
                title: "Chat";
                activated => { root.selected-view = 0; }
            }

            MenuItem {
                title: "Configure";
                activated => {
                    root.selected-view = root.selected-view == 0 ? 1 : root.selected-view;
                }
            }

            MenuSeparator {}

            MenuItem {
                title: "Refresh";
                activated => { root.refresh(); }
            }

            MenuItem {
                title: "Toggle Theme";
                activated => { root.theme-mode = root.theme-mode == 0 ? 1 : 0; }
            }
        }

        Menu {
            title: "Window";

            MenuItem {
                title: "Minimize";
                activated => { root.minimize-window(); }
            }

            MenuItem {
                title: "Zoom";
                activated => { root.toggle-maximize-window(); }
            }
        }

        Menu {
            title: "Help";

            MenuItem {
                title: "Project Guide";
                activated => { root.open-project-guide(); }
            }

            MenuItem {
                title: "Local Models Guide";
                activated => { root.open-local-models-guide(); }
            }
        }
    }

    property <bool> chat-mode: root.selected-view == 0;
    property <bool> models-mode: root.selected-view == 1 || root.selected-view == 2;
    property <bool> configure-mode: root.selected-view >= 3;
    property <brush> app-background: root.theme-mode == 0 ? #2a2d33 : #0f1012;
    property <brush> shell-fill: root.theme-mode == 0 ? #1e2127 : #0b0b0c;
    property <brush> shell-inner: root.theme-mode == 0 ? #262a31 : #141517;
    property <brush> panel-fill: root.theme-mode == 0 ? #30343c : #17181a;
    property <brush> panel-strong: root.theme-mode == 0 ? #353941 : #1b1c1f;
    property <brush> panel-soft: root.theme-mode == 0 ? #25282e : #121315;
    property <brush> chip-fill: root.theme-mode == 0 ? #181a1f : #0f1012;
    property <brush> chip-active: root.theme-mode == 0 ? #5e6470 : #303236;
    property <brush> composer-fill: root.theme-mode == 0 ? #2d3138 : #17181a;
    property <brush> row-fill: root.theme-mode == 0 ? #3a3f47 : #17181a;
    property <brush> row-alt-fill: root.theme-mode == 0 ? #343940 : #131417;
    property <brush> row-selected-fill: root.theme-mode == 0 ? #545a66 : #2a2d31;
    property <brush> orb-fill: root.theme-mode == 0
        ? @radial-gradient(circle, #f3f5f8 0%, #d6dbe3 52%, #b6bfcb 100%)
        : @radial-gradient(circle, #fbfbfb 0%, #d4d4d4 100%);
    property <color> shell-edge: root.theme-mode == 0 ? #ffffff16 : #ffffff10;
    property <color> accent-edge: root.theme-mode == 0 ? #ffffff10 : #ffffff10;
    property <color> text-primary: #f6f7fb;
    property <color> text-secondary: root.theme-mode == 0 ? #cfd4dd : #b8b8b8;
    property <color> text-muted: root.theme-mode == 0 ? #98a0ab : #777777;

    Rectangle {
        width: 100%;
        height: 100%;
        background: #00000000;

        shortcut-scope := FocusScope {
            width: parent.width;
            height: parent.height;

            key-pressed(event) => {
                if ((event.modifiers.control || event.modifiers.meta) && event.text == ",") {
                    root.selected-view = 5;
                    return accept;
                } else if ((event.modifiers.control || event.modifiers.meta) && (event.text == "w" || event.text == "W")) {
                    root.close-window();
                    return accept;
                } else if ((event.modifiers.control || event.modifiers.meta) && (event.text == "m" || event.text == "M")) {
                    root.minimize-window();
                    return accept;
                } else if ((event.modifiers.control || event.modifiers.meta) && (event.text == "q" || event.text == "Q")) {
                    root.quit-app();
                    return accept;
                }
                reject
            }

            PanelCard {
                x: 4px;
                y: 4px;
                width: parent.width - 8px;
                height: parent.height - 8px;
                fill: root.shell-fill;
                edge: root.shell-edge;
                radius: 24px;

                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: root.app-background;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding: 18px;
                        spacing: 16px;

                        Rectangle {
                            height: 44px;
                            background: #00000000;

                            TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: grab;
                                pointer-event(event) => {
                                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                        root.begin-window-drag();
                                    }
                                }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                spacing: 14px;

                                HorizontalLayout {
                                    spacing: 10px;

                                    TrafficLight {
                                        fill: #ff5f57;
                                        hover-fill: #ff7b74;
                                        symbol: "×";
                                        invoke => { root.close-window(); }
                                    }

                                    TrafficLight {
                                        fill: #febc2e;
                                        hover-fill: #ffd45b;
                                        symbol: "−";
                                        invoke => { root.minimize-window(); }
                                    }

                                    TrafficLight {
                                        fill: #28c840;
                                        hover-fill: #52db6b;
                                        symbol: "+";
                                        invoke => { root.toggle-maximize-window(); }
                                    }

                                    IconCircle {
                                        label: "≡";
                                        fill: root.chip-fill;
                                        text-color: #ffffff;
                                        invoke => { root.chat-drawer-open = !root.chat-drawer-open; }
                                    }
                                }

                                Rectangle { horizontal-stretch: 1; background: #00000000; }

                                Rectangle {
                                    width: 348px;
                                    height: 40px;
                                    border-radius: 20px;
                                    background: root.chip-fill;
                                    border-width: 1px;
                                    border-color: root.shell-edge;

                                    HorizontalLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        padding: 4px;
                                        spacing: 6px;

                                        PillButton {
                                            label: "Chat";
                                            selected: root.chat-mode;
                                            selected-fill: root.chip-active;
                                            idle-fill: #00000000;
                                            selected-text: root.text-primary;
                                            idle-text: root.text-secondary;
                                            horizontal-stretch: 1;
                                            invoke => { root.selected-view = 0; }
                                        }

                                        PillButton {
                                            label: "Models";
                                            selected: root.models-mode;
                                            selected-fill: root.chip-active;
                                            idle-fill: #00000000;
                                            selected-text: root.text-primary;
                                            idle-text: root.text-secondary;
                                            horizontal-stretch: 1;
                                            invoke => { root.selected-view = 1; }
                                        }

                                        PillButton {
                                            label: "Configure";
                                            selected: root.configure-mode;
                                            selected-fill: root.chip-active;
                                            idle-fill: #00000000;
                                            selected-text: root.text-primary;
                                            idle-text: root.text-secondary;
                                            horizontal-stretch: 1;
                                            invoke => { root.selected-view = 3; }
                                        }
                                    }
                                }

                                Rectangle { horizontal-stretch: 1; background: #00000000; }

                                IconCircle {
                                    label: root.theme-mode == 0 ? "☾" : "☀";
                                    fill: root.chip-fill;
                                    text-color: #ffffff;
                                    invoke => { root.set-theme-mode(root.theme-mode == 0 ? 1 : 0); }
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: #00000000;

                            if (root.chat-mode) : Rectangle {
                                width: parent.width;
                                height: parent.height;
                                background: #00000000;

                                if (root.chat-drawer-open) : PanelCard {
                                    x: 0px;
                                    y: 0px;
                                    width: 300px;
                                    height: parent.height;
                                    fill: root.panel-soft;
                                    edge: root.shell-edge;
                                    radius: 22px;

                                    VerticalLayout {
                                        padding: 16px;
                                        spacing: 12px;

                                        HorizontalLayout {
                                            SectionTitle { text: "Saved Chats"; }
                                            Rectangle { horizontal-stretch: 1; background: #00000000; }
                                            Button { text: "Close"; clicked => { root.chat-drawer-open = false; } }
                                        }

                                        Rectangle {
                                            vertical-stretch: 1;
                                            background: #00000000;

                                            if (root.saved-chat-items.length == 0) : EmptyState {
                                                width: parent.width;
                                                height: parent.height;
                                                title: "No saved chats yet";
                                                body: "Start a conversation and it will appear here.";
                                                title-color: root.text-primary;
                                                body-color: root.text-secondary;
                                            }

                                            if (root.saved-chat-items.length > 0) : ListView {
                                                width: parent.width;
                                                height: parent.height;
                                                for item[index] in root.saved-chat-items : StreamRow {
                                                    value: item;
                                                    alternate: Math.mod(index, 2) == 1;
                                                    selected: index == root.selected-saved-chat-index;
                                                    interactive: true;
                                                    fill: root.row-fill;
                                                    alternate-fill: root.row-alt-fill;
                                                    selected-fill: root.row-selected-fill;
                                                    edge: root.shell-edge;
                                                    text-color: root.text-primary;
                                                    invoke => { root.select-saved-chat-item(index); }
                                                }
                                            }
                                        }
                                    }
                                }

                                if (root.chat-items.length == 0) : Rectangle {
                                    width: parent.width;
                                    height: parent.height;
                                    background: #00000000;

                                    Rectangle {
                                        width: 760px;
                                        height: 328px;
                                        x: (parent.width - self.width) / 2;
                                        y: 64px;
                                        background: #00000000;

                                        Text {
                                            width: parent.width;
                                            y: 0px;
                                            horizontal-alignment: center;
                                            text: root.greeting-text;
                                            color: root.text-primary;
                                            font-size: 38px;
                                            font-weight: 800;
                                            font-family: "SF Pro Display";
                                        }

                                        Text {
                                            width: parent.width;
                                            y: 60px;
                                            horizontal-alignment: center;
                                            text: "How can TritPack help you today?";
                                            color: root.text-secondary;
                                            font-size: 17px;
                                            font-family: "SF Pro Display";
                                        }

                                        Rectangle {
                                            x: 0px;
                                            y: 124px;
                                            width: parent.width;
                                            height: 204px;
                                            background: #00000000;

                                            GridLayout {
                                                width: parent.width;
                                                height: parent.height;
                                                spacing: 14px;

                                                QuickTile {
                                                    row: 0;
                                                    col: 0;
                                                    title: "Import a model";
                                                    subtitle: "Bring in a local GGUF and move it into the TritPack flow.";
                                                    icon: "↥";
                                                    fill: root.panel-fill;
                                                    edge: root.accent-edge;
                                                    title-color: root.text-primary;
                                                    body-color: root.text-secondary;
                                                    invoke => { root.selected-view = 1; }
                                                }

                                                QuickTile {
                                                    row: 0;
                                                    col: 1;
                                                    title: "Discover GGUFs";
                                                    subtitle: "Search Hugging Face repositories and queue downloads.";
                                                    icon: "⌕";
                                                    fill: root.panel-fill;
                                                    edge: root.accent-edge;
                                                    title-color: root.text-primary;
                                                    body-color: root.text-secondary;
                                                    invoke => { root.selected-view = 2; }
                                                }

                                                QuickTile {
                                                    row: 1;
                                                    col: 0;
                                                    title: "Check the queue";
                                                    subtitle: "Monitor downloads, conversions, verification, and runtime prep.";
                                                    icon: "≣";
                                                    fill: root.panel-fill;
                                                    edge: root.accent-edge;
                                                    title-color: root.text-primary;
                                                    body-color: root.text-secondary;
                                                    invoke => { root.selected-view = 3; }
                                                }

                                                QuickTile {
                                                    row: 1;
                                                    col: 1;
                                                    title: "Open settings";
                                                    subtitle: "Review runtime health, tokens, and release preferences.";
                                                    icon: "⚙";
                                                    fill: root.panel-fill;
                                                    edge: root.accent-edge;
                                                    title-color: root.text-primary;
                                                    body-color: root.text-secondary;
                                                    invoke => { root.selected-view = 5; }
                                                }
                                            }
                                        }
                                    }
                                }

                                if (root.chat-items.length > 0) : PanelCard {
                                    x: (parent.width - 920px) / 2;
                                    y: 6px;
                                    width: 920px;
                                    height: parent.height - 12px;
                                    fill: root.panel-soft;
                                    edge: root.shell-edge;
                                    radius: 24px;

                                    VerticalLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        padding: 18px;
                                        spacing: 12px;

                                        HorizontalLayout {
                                            SectionTitle { text: "Conversation"; }
                                            Rectangle { horizontal-stretch: 1; background: #00000000; }
                                            BodyText { text: root.status-text; }
                                        }

                                        ListView {
                                            width: parent.width;
                                            height: parent.height;
                                            for item[index] in root.chat-items : StreamRow {
                                                value: item;
                                                alternate: Math.mod(index, 2) == 1;
                                                fill: root.row-fill;
                                                alternate-fill: root.row-alt-fill;
                                                edge: root.shell-edge;
                                                text-color: root.text-primary;
                                            }
                                        }
                                    }
                                }
                            }

                            if (!root.chat-mode) : HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                spacing: 18px;

                                PanelCard {
                                    width: 176px;
                                    fill: root.panel-soft;
                                    edge: root.shell-edge;
                                    radius: 22px;
                                    vertical-stretch: 1;

                                    VerticalLayout {
                                        padding: 14px;
                                        spacing: 10px;

                                        if (root.models-mode) : SidebarItem {
                                            label: "Models";
                                            selected: root.selected-view == 1;
                                            selected-fill: root.chip-active;
                                            idle-fill: #00000000;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 1; }
                                        }

                                        if (root.models-mode) : SidebarItem {
                                            label: "Discover";
                                            selected: root.selected-view == 2;
                                            selected-fill: root.chip-active;
                                            idle-fill: #00000000;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 2; }
                                        }

                                        if (root.configure-mode) : SidebarItem {
                                            label: "Queue";
                                            selected: root.selected-view == 3;
                                            selected-fill: root.chip-active;
                                            idle-fill: #00000000;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 3; }
                                        }

                                        if (root.configure-mode) : SidebarItem {
                                            label: "Runtime";
                                            selected: root.selected-view == 4;
                                            selected-fill: root.chip-active;
                                            idle-fill: #00000000;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 4; }
                                        }

                                        if (root.configure-mode) : SidebarItem {
                                            label: "Settings";
                                            selected: root.selected-view == 5;
                                            selected-fill: root.chip-active;
                                            idle-fill: #00000000;
                                            title-color: root.text-primary;
                                            body-color: root.text-secondary;
                                            invoke => { root.selected-view = 5; }
                                        }

                                        Rectangle { vertical-stretch: 1; background: #00000000; }

                                        BodyText {
                                            text: root.status-text;
                                            wrap: word-wrap;
                                        }
                                    }
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    background: #00000000;

                                    if (root.selected-view == 1) : HorizontalLayout {
                                        spacing: 16px;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;

                                        PanelCard {
                                            width: 400px;
                                            fill: root.panel-fill;
                                            edge: root.shell-edge;
                                            radius: 22px;
                                            vertical-stretch: 1;

                                            VerticalLayout {
                                                padding: 16px;
                                                spacing: 12px;

                                                HorizontalLayout {
                                                    SectionTitle { text: "Your Models"; }
                                                    Rectangle { horizontal-stretch: 1; background: #00000000; }
                                                    Button { text: "Refresh"; clicked => { root.refresh(); } }
                                                }

                                                BodyText { text: "Select a model here. Chat will use the current selection."; }

                                                Rectangle {
                                                    vertical-stretch: 1;
                                                    background: #00000000;

                                                    if (root.library-items.length == 0) : EmptyState {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        title: "No models imported yet";
                                                        body: "Import a GGUF model below, or use Discover to download one first.";
                                                        title-color: root.text-primary;
                                                        body-color: root.text-secondary;
                                                    }

                                                    if (root.library-items.length > 0) : ListView {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        for item[index] in root.library-items : StreamRow {
                                                            value: item;
                                                            alternate: Math.mod(index, 2) == 1;
                                                            selected: index == root.selected-library-index;
                                                            interactive: true;
                                                            fill: root.row-fill;
                                                            alternate-fill: root.row-alt-fill;
                                                            selected-fill: root.row-selected-fill;
                                                            edge: root.shell-edge;
                                                            text-color: root.text-primary;
                                                            invoke => { root.select-library-item(index); }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            horizontal-stretch: 1;
                                            spacing: 16px;

                                            PanelCard {
                                                fill: root.panel-strong;
                                                edge: root.shell-edge;
                                                radius: 22px;
                                                height: 126px;

                                                VerticalLayout {
                                                    padding: 16px;
                                                    spacing: 12px;

                                                    SectionTitle { text: "Import Local GGUF"; }
                                                    HorizontalLayout {
                                                        spacing: 10px;
                                                        LineEdit { text <=> root.import-path; placeholder-text: "/path/to/model.gguf"; horizontal-stretch: 1; }
                                                        Button { text: "Import"; clicked => { root.import-local(root.import-path); } }
                                                    }
                                                }
                                            }

                                            PanelCard {
                                                fill: root.panel-fill;
                                                edge: root.shell-edge;
                                                radius: 22px;
                                                vertical-stretch: 1;

                                                VerticalLayout {
                                                    padding: 16px;
                                                    spacing: 12px;

                                                    SectionTitle { text: "Selected Model"; }

                                                    Text {
                                                        height: 56px;
                                                        horizontal-stretch: 1;
                                                        text: root.model-id-input == "" ? "No model selected" : root.model-id-input;
                                                        color: root.text-primary;
                                                        font-size: 15px;
                                                        font-weight: 700;
                                                        wrap: word-wrap;
                                                        font-family: "SF Pro Display";
                                                    }

                                                    HorizontalLayout {
                                                        spacing: 10px;
                                                        Button { text: "Open in Chat"; clicked => { root.selected-view = 0; } }
                                                        Button { text: "Inspect"; clicked => { root.inspect-model(root.model-id-input); root.selected-view = 4; } }
                                                        Button { text: "Convert"; clicked => { root.queue-convert(root.model-id-input); } }
                                                    }

                                                    HorizontalLayout {
                                                        spacing: 10px;
                                                        Button { text: "Prepare"; clicked => { root.prepare-runtime(root.model-id-input); } }
                                                        Button { text: "Clear Cache"; clicked => { root.clear-cache(root.model-id-input); } }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    if (root.selected-view == 2) : VerticalLayout {
                                        spacing: 16px;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;

                                        HorizontalLayout {
                                            spacing: 16px;
                                            height: 164px;

                                            PanelCard {
                                                fill: root.panel-strong;
                                                edge: root.shell-edge;
                                                radius: 22px;
                                                horizontal-stretch: 1;

                                                VerticalLayout {
                                                    padding: 16px;
                                                    spacing: 12px;

                                                    SectionTitle { text: "Search Hugging Face"; }
                                                    HorizontalLayout {
                                                        spacing: 10px;
                                                        LineEdit { text <=> root.hf-query; placeholder-text: "e.g. llama 3 gguf"; horizontal-stretch: 1; }
                                                        Button { text: "Search"; clicked => { root.search-models(root.hf-query); } }
                                                    }

                                                    HorizontalLayout {
                                                        spacing: 10px;
                                                        LineEdit { text <=> root.search-index; placeholder-text: "Selected result #"; horizontal-stretch: 1; }
                                                        Button { text: "Download Selected"; clicked => { root.download-search-result(root.search-index); } }
                                                    }
                                                }
                                            }

                                            PanelCard {
                                                fill: root.panel-strong;
                                                edge: root.shell-edge;
                                                radius: 22px;
                                                horizontal-stretch: 1;

                                                VerticalLayout {
                                                    padding: 16px;
                                                    spacing: 12px;

                                                    SectionTitle { text: "Direct GGUF URL"; }
                                                    HorizontalLayout {
                                                        spacing: 10px;
                                                        LineEdit { text <=> root.direct-url; placeholder-text: "https://.../model.gguf"; horizontal-stretch: 1; }
                                                        Button { text: "Download"; clicked => { root.download-url(root.direct-url); } }
                                                    }

                                                    BodyText { text: "Downloads will appear in Models after the queue finishes."; }
                                                }
                                            }
                                        }

                                        PanelCard {
                                            fill: root.panel-fill;
                                            edge: root.shell-edge;
                                            vertical-stretch: 1;

                                            VerticalLayout {
                                                padding: 16px;
                                                spacing: 12px;

                                                SectionTitle { text: "Search Results"; }

                                                Rectangle {
                                                    vertical-stretch: 1;
                                                    background: #00000000;

                                                    if (root.search-items.length == 0) : EmptyState {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        title: "No search results yet";
                                                        body: "Search Hugging Face for a GGUF model or paste a direct artifact URL.";
                                                        title-color: root.text-primary;
                                                        body-color: root.text-secondary;
                                                    }

                                                    if (root.search-items.length > 0) : ListView {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        for item[index] in root.search-items : StreamRow {
                                                            value: item;
                                                            alternate: Math.mod(index, 2) == 1;
                                                            selected: index == root.selected-search-index;
                                                            interactive: true;
                                                            fill: root.row-fill;
                                                            alternate-fill: root.row-alt-fill;
                                                            selected-fill: root.row-selected-fill;
                                                            edge: root.shell-edge;
                                                            text-color: root.text-primary;
                                                            invoke => { root.select-search-item(index); }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    if (root.selected-view == 3) : VerticalLayout {
                                        spacing: 14px;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;

                                        PanelCard {
                                            fill: root.panel-strong;
                                            edge: root.shell-edge;
                                            radius: 22px;
                                            height: 72px;

                                            HorizontalLayout {
                                                width: parent.width;
                                                height: parent.height;
                                                padding: 14px;
                                                spacing: 10px;

                                                LineEdit { text <=> root.job-id-input; placeholder-text: "Job ID"; horizontal-stretch: 1; }
                                                Button { text: "Cancel"; clicked => { root.cancel-job(root.job-id-input); } }
                                                Button { text: "Refresh"; clicked => { root.refresh(); } }
                                            }
                                        }

                                        PanelCard {
                                            fill: root.panel-fill;
                                            edge: root.shell-edge;
                                            vertical-stretch: 1;

                                            if (root.job-items.length == 0) : EmptyState {
                                                width: parent.width;
                                                height: parent.height;
                                                title: "No jobs in flight";
                                                body: "Queue a download, conversion, or runtime preparation job to populate this view.";
                                                title-color: root.text-primary;
                                                body-color: root.text-secondary;
                                            }

                                            if (root.job-items.length > 0) : ListView {
                                                width: parent.width;
                                                height: parent.height;
                                                for item[index] in root.job-items : StreamRow {
                                                    value: item;
                                                    alternate: Math.mod(index, 2) == 1;
                                                    fill: root.row-fill;
                                                    alternate-fill: root.row-alt-fill;
                                                    edge: root.shell-edge;
                                                    text-color: root.text-primary;
                                                }
                                            }
                                        }
                                    }

                                    if (root.selected-view == 4) : HorizontalLayout {
                                        spacing: 16px;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;

                                        PanelCard {
                                            fill: root.panel-fill;
                                            edge: root.shell-edge;
                                            horizontal-stretch: 1;
                                            vertical-stretch: 1;

                                            VerticalLayout {
                                                padding: 16px;
                                                spacing: 12px;

                                                HorizontalLayout {
                                                    SectionTitle { text: "Selected Model Detail"; }
                                                    Rectangle { horizontal-stretch: 1; background: #00000000; }
                                                    Button { text: "Inspect"; clicked => { root.inspect-model(root.model-id-input); } }
                                                    Button { text: "Prepare"; clicked => { root.prepare-runtime(root.model-id-input); } }
                                                }

                                                Rectangle {
                                                    vertical-stretch: 1;
                                                    background: #00000000;

                                                    if (root.detail-items.length == 0) : EmptyState {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        title: "No model detail loaded";
                                                        body: "Select a model in Models, then inspect it to see metadata and runtime preparation information.";
                                                        title-color: root.text-primary;
                                                        body-color: root.text-secondary;
                                                    }

                                                    if (root.detail-items.length > 0) : ListView {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        for item[index] in root.detail-items : StreamRow {
                                                            value: item;
                                                            alternate: Math.mod(index, 2) == 1;
                                                            fill: root.row-fill;
                                                            alternate-fill: root.row-alt-fill;
                                                            edge: root.shell-edge;
                                                            text-color: root.text-primary;
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        PanelCard {
                                            fill: root.panel-fill;
                                            edge: root.shell-edge;
                                            width: 360px;
                                            vertical-stretch: 1;

                                            VerticalLayout {
                                                padding: 16px;
                                                spacing: 12px;

                                                HorizontalLayout {
                                                    SectionTitle { text: "Runtime Diagnostics"; }
                                                    Rectangle { horizontal-stretch: 1; background: #00000000; }
                                                    Button { text: "Refresh"; clicked => { root.refresh-runtime(); } }
                                                }

                                                Rectangle {
                                                    vertical-stretch: 1;
                                                    background: #00000000;

                                                    if (root.runtime-items.length == 0) : EmptyState {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        title: "No runtime diagnostics";
                                                        body: "Refresh to inspect the worker, bundled runtime, and current macOS desktop setup.";
                                                        title-color: root.text-primary;
                                                        body-color: root.text-secondary;
                                                    }

                                                    if (root.runtime-items.length > 0) : ListView {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        for item[index] in root.runtime-items : StreamRow {
                                                            value: item;
                                                            alternate: Math.mod(index, 2) == 1;
                                                            fill: root.row-fill;
                                                            alternate-fill: root.row-alt-fill;
                                                            edge: root.shell-edge;
                                                            text-color: root.text-primary;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    if (root.selected-view == 5) : PanelCard {
                                        fill: root.panel-fill;
                                        edge: root.shell-edge;
                                        radius: 22px;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;

                                        VerticalLayout {
                                            padding: 20px;
                                            spacing: 18px;

                                            SectionTitle { text: "Account"; }
                                            BodyText { text: "Save an optional Hugging Face token for gated or private GGUF repositories."; }
                                            LineEdit { text <=> root.hf-token; placeholder-text: "Hugging Face token"; }
                                            Button { text: "Save Token"; clicked => { root.save-token(root.hf-token); } }

                                            Rectangle { height: 1px; background: root.shell-edge; }

                                            SectionTitle { text: "Appearance"; }
                                            HorizontalLayout {
                                                spacing: 10px;

                                                PillButton {
                                                    label: "Smoke Glass";
                                                    selected: root.theme-mode == 0;
                                                    selected-fill: root.chip-active;
                                                    idle-fill: root.chip-fill;
                                                    selected-text: root.text-primary;
                                                    idle-text: root.text-secondary;
                                                    preferred-width: 160px;
                                                    invoke => { root.set-theme-mode(0); }
                                                }

                                                PillButton {
                                                    label: "Blackout";
                                                    selected: root.theme-mode == 1;
                                                    selected-fill: root.chip-active;
                                                    idle-fill: root.chip-fill;
                                                    selected-text: root.text-primary;
                                                    idle-text: root.text-secondary;
                                                    preferred-width: 140px;
                                                    invoke => { root.set-theme-mode(1); }
                                                }
                                            }

                                            Rectangle { height: 1px; background: root.shell-edge; }

                                            SectionTitle { text: "Runtime"; }
                                            BodyText { text: "Use Runtime to inspect worker health, prepared caches, and current backend readiness."; }
                                        }
                                    }
                                }
                            }
                        }

                        if (root.chat-mode) : PanelCard {
                            fill: root.shell-inner;
                            edge: root.shell-edge;
                            radius: 24px;
                            height: 86px;

                            VerticalLayout {
                                width: parent.width;
                                height: parent.height;
                                padding: 14px;
                                spacing: 0px;

                                PanelCard {
                                    fill: root.composer-fill;
                                    edge: root.shell-edge;
                                    radius: 20px;
                                    vertical-stretch: 1;

                                    HorizontalLayout {
                                        width: parent.width;
                                        height: parent.height;
                                        padding: 12px;
                                        spacing: 12px;

                                        Button {
                                            text: "Models";
                                            clicked => { root.selected-view = 1; }
                                        }

                                        LineEdit {
                                            text <=> root.chat-prompt;
                                            placeholder-text: root.model-id-input == "" ? "Select a model in Models, then send a message" : "Message TritPack";
                                            horizontal-stretch: 1;
                                            accepted => { root.send-prompt(root.model-id-input, root.chat-prompt); }
                                        }

                                        Button {
                                            text: "Send";
                                            clicked => { root.send-prompt(root.model-id-input, root.chat-prompt); }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
